#!/usr/bin/env sh
set -eu

if [ -n "${DEVCONTAINER_TAB_TITLE:-}" ]; then
  printf '󰡨 %s\n' "$DEVCONTAINER_TAB_TITLE"
elif [ -f /.dockerenv ] || grep -qaE '/docker/|/kubepods/|/containerd/' /proc/1/cgroup 2>/dev/null; then
  name="$(hostname -s 2>/dev/null || hostname)"
  printf ' %s\n' "$name"
else
  name="${HOST:-$(hostname -s 2>/dev/null || hostname)}"
  printf '󰌢 %s\n' "$name"
fi
